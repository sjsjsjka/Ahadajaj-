// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Document ID: {uid}
// Fields:
//   - uid: string (required)
//   - email: string (required, email format)
//   - displayName: string
//   - role: string (required, 'admin' or 'user')
//   - credits: number (required)
//   - createdAt: timestamp
//
// Collection: payments
// Document ID: auto-generated
// Fields:
//   - uid: string (required)
//   - email: string (required)
//   - amount: number (required)
//   - credits: number (required)
//   - method: string (required, 'bkash', 'nagad', 'gumroad')
//   - transactionId: string (required)
//   - status: string (required, 'pending', 'approved', 'rejected')
//   - timestamp: timestamp (required)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || 
         (request.auth.token.email == "enjoystudio0030@gmail.com" && request.auth.token.email_verified == true));
    }
    
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'credits']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'user'] &&
             data.credits is number;
    }
    
    function isValidPayment(data) {
      return data.keys().hasAll(['uid', 'email', 'amount', 'credits', 'method', 'transactionId', 'status', 'timestamp']) &&
             data.uid == request.auth.uid &&
             data.email is string &&
             data.amount is number &&
             data.credits is number &&
             data.method in ['bkash', 'nagad', 'gumroad'] &&
             data.transactionId is string &&
             data.transactionId.size() > 0 &&
             data.status == 'pending' &&
             data.timestamp is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      
      // Users can create their own profile as 'user' with 0 credits
      allow create: if isOwner(userId) && 
                      request.resource.data.role == 'user' && 
                      request.resource.data.credits == 0 &&
                      isValidUser(request.resource.data);
      
      // Only admins can update role or credits
      allow update: if isAdmin() && isValidUser(request.resource.data);
      
      // Users can update their own displayName but not role/credits
      allow update: if isOwner(userId) && 
                      request.resource.data.role == resource.data.role && 
                      request.resource.data.credits == resource.data.credits &&
                      isValidUser(request.resource.data);
    }

    match /payments/{paymentId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.uid == request.auth.uid);
      
      // Users can submit a pending payment
      allow create: if isAuthenticated() && isValidPayment(request.resource.data);
      
      // Only admins can update payment status
      allow update: if isAdmin() && 
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']) &&
                      request.resource.data.status in ['approved', 'rejected'];
    }
  }
}
